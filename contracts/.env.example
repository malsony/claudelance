# --- Sepolia (shared single-key OK) ----------------------------------------
DEPLOYER_PRIVATE_KEY=0x...
DEPLOYER_ADDRESS=0x...
CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org/
CUSD_SEPOLIA=

# For Sepolia broadcasts, set ALLOW_SHARED_ADMIN_WALLETS=true to let the deploy
# script accept identical deployer/owner/treasury/relayer addresses.

# --- Mainnet (chainid 42220 enforces distinct keys) -----------------------
CELO_MAINNET_RPC=https://forno.celo.org
CUSD_MAINNET=0x765DE816845861e75A25fCA122bb6898B8B1282a

MAINNET_DEPLOYER_PRIVATE_KEY=0x...
MAINNET_DEPLOYER_ADDRESS=0x...
MAINNET_OWNER_PRIVATE_KEY=0x...
MAINNET_OWNER_ADDRESS=0x...
MAINNET_TREASURY_PRIVATE_KEY=0x...
MAINNET_TREASURY_ADDRESS=0x...
MAINNET_RELAYER_PRIVATE_KEY=0x...
MAINNET_RELAYER_ADDRESS=0x...

# --- Verification ----------------------------------------------------------
# Unified Etherscan API V2 key — works for Celo + 60+ other EVM chains.
# Get one at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# --- Constructor args (override when broadcasting) ------------------------
# Deploy.s.sol reads these. For mainnet, set them to MAINNET_* equivalents.
TREASURY_ADDRESS=
CI_RELAYER_ADDRESS=
OWNER_ADDRESS=
CUSD_ADDRESS=
