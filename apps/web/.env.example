# Public RPC + chain id resolved from contracts/deployments/celo-sepolia.json by default.
# Override only when targeting a non-default network.
NEXT_PUBLIC_DEFAULT_CHAIN=celo-sepolia
NEXT_PUBLIC_CELO_SEPOLIA_RPC=https://forno.celo-sepolia.celo-testnet.org/
NEXT_PUBLIC_CELO_MAINNET_RPC=https://forno.celo.org

# Optional: WalletConnect project id (only needed when supporting external wallets).
NEXT_PUBLIC_WC_PROJECT_ID=55218dcc95eb0de6ce4665a539b609c5

# Privy app id for browser-side auth.
NEXT_PUBLIC_PRIVY_APP_ID=
